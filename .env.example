# ====================================
# FRONTEND - Sistema CCO
# ====================================

# API Backend URL
# Desenvolvimento: http://localhost:5001/api
# Produção: https://seu-backend.vercel.app/api
VITE_API_URL=http://localhost:5001/api

# Nome da Aplicação
VITE_APP_NAME=Sistema CCO

# Supabase Configuration (opcional para frontend)
# Mesmo que você use Supabase, pode não precisar no frontend
# se todas as chamadas passam pelo backend
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-publica-aqui

# ====================================
# INSTRUÇÕES
# ====================================
# 1. Copie este arquivo para .env
# 2. Substitua os valores com suas credenciais reais
# 3. NUNCA commite o arquivo .env no git
