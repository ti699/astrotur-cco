# =============================================================
# Frontend — Sistema CCO (Exemplo de configuração)
# Copie este arquivo para .env (dev) ou .env.production (prod).
# NUNCA commite o arquivo .env com dados reais no repositório.
# =============================================================

# ── URL do backend Express ────────────────────────────────────
# Desenvolvimento: proxy Vite → basta deixar em branco ou apontar localhost
# Produção VPS: URL pública do backend (sem /api trailing)
VITE_API_URL=https://seudominio.com.br

# ── Nome da Aplicação ─────────────────────────────────────────
VITE_APP_NAME=Sistema CCO

# ── Variáveis legadas — NÃO SÃO MAIS NECESSÁRIAS ─────────────
# Removidas na migração para VPS. O frontend não acessa mais o
# Supabase diretamente. Apague após validação.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# VITE_SUPABASE_SERVICE_KEY=
