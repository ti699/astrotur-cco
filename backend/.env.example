# =============================================================
# Backend — Sistema CCO (Exemplo de configuração para VPS)
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env com dados reais no repositório.
# =============================================================

# ── Banco de dados PostgreSQL local ───────────────────────────
DATABASE_URL=postgresql://cco_user:SENHA_AQUI@localhost:5432/cco_db
DATABASE_SSL=false

# ── Servidor Express ──────────────────────────────────────────
PORT=5001
NODE_ENV=production

# ── CORS — domínios permitidos (frontend) ────────────────────
CORS_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br
FRONTEND_URL=https://seudominio.com.br

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=troque_por_uma_string_aleatoria_de_pelo_menos_32_chars
JWT_EXPIRES_IN=7d

# ── SMTP (Gmail) ──────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=senha_de_app_gmail_16_chars
EMAIL_FROM="Sistema CCO <seu_email@gmail.com>"

# ── Upload de arquivos ────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── Variáveis legadas — NÃO SÃO MAIS NECESSÁRIAS ─────────────
# Removidas na migração para VPS. Apague após validação.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# DB_HOST=
# DB_PORT=
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
EMAIL_SECURE=false
EMAIL_USER=seu-email@gmail.com
EMAIL_PASSWORD=sua_senha_de_app_do_gmail
EMAIL_FROM=noreply@seudominio.com

# UPLOAD
MAX_FILE_SIZE=10485760
STORAGE_BUCKET=ocorrencias-anexos