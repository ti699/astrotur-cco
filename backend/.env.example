# ====================================
# BACKEND - Sistema CCO - Configuracao
# Copie este arquivo para .env e preencha com seus valores reais
# ====================================

# DATABASE - Supabase PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true
DB_HOST=db.SEU-PROJETO.supabase.co
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=SUA_SENHA_AQUI

# SUPABASE
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# JWT
JWT_SECRET=gere_uma_chave_secreta_segura_com_minimo_32_caracteres
JWT_EXPIRES_IN=7d

# SERVER
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# EMAIL SMTP (Gmail App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=seu-email@gmail.com
EMAIL_PASSWORD=sua_senha_de_app_do_gmail
EMAIL_FROM=noreply@seudominio.com

# UPLOAD
MAX_FILE_SIZE=10485760
STORAGE_BUCKET=ocorrencias-anexos